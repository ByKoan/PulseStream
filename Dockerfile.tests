FROM python:3.11-slim

WORKDIR /app

# Dependencias del sistema
RUN apt-get update && \
    apt-get install -y --no-install-recommends ffmpeg && \
    rm -rf /var/lib/apt/lists/*

# Dependencias Python de la app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Pytest y plugins
RUN pip install --no-cache-dir pytest pytest-cov pytest-html pytest-sugar

# Código fuente (igual que el webserver: COPY src/ /app/)
COPY src/ .

ENV PYTHONPATH=/app \
    DB_HOST=db \
    DB_USER=root \
    DB_PASSWORD=root \
    DB_NAME=music_db \
    BASE_MUSIC_FOLDER=/app/music \
    SECRET_KEY=test_secret_key_pytest

CMD ["pytest", "/app/tests", "-v", "--tb=short", \
     "--cov=/app", "--cov-report=term-missing", \
     "--html=/app/tests/reports/report.html", "--self-contained-html"]
